# Copy this file to .env for local testing (never commit the real .env).
# On Render, set these in the dashboard under Environment instead of a file.

# Z.ai (GLM) API key — keep this secret, never put it in the frontend.
GLM_API_KEY=

# Confirm the exact model id with First before relying on this.
GLM_MODEL=glm-4.6

# Z.ai's chat completions endpoint (confirmed against Z.ai's own API docs).
GLM_BASE_URL=https://api.z.ai/api/paas/v4/chat/completions

# A password you make up yourself, used to protect /api/sessions (GET/DELETE) so random
# people can't read everyone's interview answers. Put this same value into the frontend's
# admin view when Max wants to check results.
ADMIN_TOKEN=

# Turso (real, persistent database for saved sessions) — see README.md "Persistent storage"
# section for how to get these from the Turso dashboard. If left blank, the app falls back
# to a local JSON file that Render's free tier can wipe on restart/redeploy — fine for local
# testing, not safe for real employee data.
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

PORT=3000
